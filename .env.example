# ─────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your API keys
# NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────

# Required — Mistral AI (LLM backbone for all agents)
# Get yours at: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional — Tavily Web Search
# Enables hybrid / open_book research modes
# Get yours at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — Google Gemini (AI image generation)
# Enables automatic diagram generation inside blogs
# Get yours at: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here
